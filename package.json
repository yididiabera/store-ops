{
  "name": "store-ops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "start": "npm --workspace apps/web run start",
    "start:web": "npm --workspace apps/web run start",
    "start:api": "npm --workspace apps/api run start",
    "lint": "npm --workspace apps/web run lint",
    "typecheck:api": "npm --workspace apps/api run typecheck",
    "db:check:api": "npm --workspace apps/api run db:check",
    "db:migrate:api": "npm --workspace apps/api run db:migrate",
    "db:seed:api": "npm --workspace apps/api run db:seed",
    "db:init": "npm --workspace apps/web run db:init",
    "db:seed": "npm --workspace apps/web run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
